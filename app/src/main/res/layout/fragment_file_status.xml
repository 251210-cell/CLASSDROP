<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollViewStatus"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_pill"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_app_logo" app:tint="@color/primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:fontFamily="sans-serif-black" android:text="ClassDrop" android:textColor="@color/on_background" android:textSize="16sp" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
            <ImageView android:id="@+id/ivNotification" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="16dp" android:src="@drawable/ic_notification" app:tint="@color/primary" />
            <TextView android:id="@+id/tvAvatarInitials" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_button_primary" android:gravity="center" android:text="MA" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Main Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Estado de tu\ndocumento"
                    android:textColor="@color/primary"
                    android:textSize="26sp" />

                <!-- Timeline -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="vertical">

                    <!-- Step 1: Archivo Recibido -->
                    <LinearLayout
                        android:id="@+id/step1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center_horizontal" android:orientation="vertical">
                            <ImageView android:id="@+id/ivStep1" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_button_primary" android:padding="8dp" android:src="@drawable/ic_check_circle" app:tint="@color/white" />
                            <View android:id="@+id/line1" android:layout_width="2dp" android:layout_height="60dp" android:background="@color/primary" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvTitleStep1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Archivo Recibido" android:textColor="@color/on_background" android:textStyle="bold" />
                            <TextView android:id="@+id/tvTimeReceived" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hoy, 10:45 AM" android:textColor="@color/text_secondary" android:textSize="11sp" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Tu archivo se ha cargado correctamente en nuestros servidores." android:textColor="@color/text_secondary" android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 2: Escaneo de Seguridad -->
                    <LinearLayout
                        android:id="@+id/step2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center_horizontal" android:orientation="vertical">
                            <ImageView android:id="@+id/ivStep2" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_button_primary" android:padding="8dp" android:src="@drawable/ic_status_shield" app:tint="@color/white" />
                            <View android:id="@+id/line2" android:layout_width="2dp" android:layout_height="100dp" android:background="@color/primary" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvTitleStep2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Escaneo de Seguridad" android:textColor="@color/primary" android:textStyle="bold" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/statusProgressBar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:progress="65"
                                app:indicatorColor="@color/primary"
                                app:trackColor="@color/outline_variant"
                                app:trackCornerRadius="8dp"
                                app:trackThickness="8dp" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Nuestra IA está analizando el contenido para asegurar que cumple con los estándares." android:textColor="@color/text_secondary" android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 3: Revisión de Calidad -->
                    <LinearLayout
                        android:id="@+id/step3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center_horizontal" android:orientation="vertical">
                            <ImageView android:id="@+id/ivStep3" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_input_pill" android:backgroundTint="@color/surface_variant" android:padding="8dp" android:src="@drawable/ic_nav_notes" app:tint="@color/placeholder" />
                            <View android:id="@+id/line3" android:layout_width="2dp" android:layout_height="60dp" android:background="@color/outline_variant" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvTitleStep3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Revisión de Calidad" android:textColor="@color/placeholder" android:textStyle="bold" />
                            <TextView android:id="@+id/tvLabelStep3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pendiente de escaneo previo" android:textColor="@color/placeholder" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Step 4: Publicación -->
                    <LinearLayout
                        android:id="@+id/step4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView android:id="@+id/ivStep4" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_input_pill" android:backgroundTint="@color/surface_variant" android:padding="8dp" android:src="@drawable/ic_app_logo" app:tint="@color/placeholder" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvTitleStep4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Publicación" android:textColor="@color/placeholder" android:textStyle="bold" />
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="El documento estará disponible pronto." android:textColor="@color/placeholder" android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Resumen del Archivo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="RESUMEN DEL ARCHIVO"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@color/file_pink_bg">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_notes"
                            app:tint="@color/file_pink_text" />
                    </FrameLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvFileNameStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Apuntes_Calculo_III_Final.pdf"
                            android:textColor="@color/on_background"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvFilePages"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24 páginas"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnViewDetails"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/primary"
                    android:text="Ver Detalles"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info Políticas -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_help" app:tint="@color/file_teal_text" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="INFORMACIÓN DE POLÍTICAS" android:textColor="@color/file_teal_text" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="En ClassDrop nos tomamos en serio la calidad académica. Si el contenido es identificado como inapropiado, el archivo será rechazado automáticamente." android:textColor="@color/on_background" android:textSize="13sp" android:lineSpacingExtra="3dp" />

                <TextView
                    android:id="@+id/tvReadRules"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Leer normas completas"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>