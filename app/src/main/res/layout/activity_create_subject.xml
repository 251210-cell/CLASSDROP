<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_down"
                    android:rotation="90"
                    app:tint="#4F46E5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Nueva Materia"
                    android:textColor="#4F46E5"
                    android:textSize="24sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/formCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="32dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/headerLayout">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Nombre -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOMBRE DE LA MATERIA"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etSubjectName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_pill"
                        android:hint="Ej: Cálculo Diferencial"
                        android:paddingHorizontal="16dp"
                        android:textColor="#1E293B"
                        android:textSize="15sp" />

                    <!-- Iconos -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="ICONO DE LA MATERIA"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:columnCount="3"
                        android:alignmentMode="alignMargins"
                        android:useDefaultMargins="true">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnIcon1"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_subject_code"
                                app:tint="#4F46E5" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnIcon2"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_subject_sigma"
                                app:tint="#4F46E5" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnIcon3"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_database"
                                app:tint="#4F46E5" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnIcon4"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_subject_structure"
                                app:tint="#4F46E5" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnIcon5"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_subject_math"
                                app:tint="#4F46E5" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnIcon6"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_subject_calc"
                                app:tint="#4F46E5" />
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Este icono representará a la materia."
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:textStyle="italic" />

                    <!-- Cuatrimestre -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="CUATRIMESTRE"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:columnCount="4"
                        android:useDefaultMargins="true">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ1"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="1"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ2"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="2"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ3"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="3"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ4"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="4"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ5"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="5"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ6"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="6"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ7"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="7"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ8"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="8"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ9"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="9"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnQ10"
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            app:cardBackgroundColor="#F1F5F9"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="10"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>

                    <!-- Acciones -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="48dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancel"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="#D1D5DB"
                            android:text="Cancelar"
                            android:textColor="#4B5563"
                            app:cornerRadius="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSave"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="#4F46E5"
                            android:text="Guardar"
                            android:textColor="@color/white"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
