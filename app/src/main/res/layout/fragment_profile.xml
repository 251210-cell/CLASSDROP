<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollViewProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_pill"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_app_logo"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-black"
                    android:text="ClassDrop"
                    android:textColor="@color/on_background"
                    android:textSize="16sp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/ivNotification"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_notification"
                app:tint="@color/primary" />
        </LinearLayout>

        <!-- Profile Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="24dp">

            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="@color/primary"
                android:gravity="center"
                android:text="MA"
                android:textColor="@color/white"
                android:textSize="44sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:text="Mariana Alvarez"
                android:textColor="@color/on_background"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tvUserCareer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ingenieria en Tecnologias de la Información"
                android:textColor="@color/primary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- INFORMACIÓN Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="INFORMACIÓN"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Nombre -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_nav_profile" app:tint="@color/primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nombre" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/tvUserInfoName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fernanda Velazquez" android:textColor="@color/on_background" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="@color/outline_variant" />

                <!-- Correo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_google_logo" app:tint="@color/primary" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Correo" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:id="@+id/tvUserInfoEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="231285@ids.upchiapas.edu.mx" android:textColor="@color/on_background" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- MI ACTIVIDAD Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="MI ACTIVIDAD"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="20dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUploads"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_upload" app:tint="@color/primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="14" android:textColor="@color/on_background" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Archivos\nsubidos" android:gravity="center" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDownloads"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_download" app:tint="@color/primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="38" android:textColor="@color/on_background" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Descargas" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFavorites"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_favorite" app:tint="@color/primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="24" android:textColor="@color/on_background" android:textSize="20sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Favoritos" android:textColor="@color/text_secondary" android:textSize="10sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Archivos subidos Section Header -->
        <RelativeLayout
            android:id="@+id/titleUploads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="24dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_nav_upload" app:tint="@color/primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Archivos subidos" android:textColor="@color/on_background" android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvSeeMoreUploads"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Ver más →"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_input_pill"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_app_logo" app:tint="@color/primary" /></FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Derivadas Parciales" android:textColor="@color/on_background" android:textStyle="bold" android:textSize="13sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cálculo - hace 2 días" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_input_pill" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:text="PDF" android:textColor="@color/primary" android:textStyle="bold" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Descargas Section Header -->
        <RelativeLayout
            android:id="@+id/titleDownloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="24dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_download" app:tint="@color/primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Descargas" android:textColor="@color/on_background" android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvSeeMoreDownloads"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Ver más →"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_input_pill"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_app_logo" app:tint="@color/primary" /></FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Guía de Estudio Redes" android:textColor="@color/on_background" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Redes I - hace 1 día" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_input_pill" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:text="PDF" android:textColor="@color/primary" android:textStyle="bold" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Favoritos Section Header -->
        <RelativeLayout
            android:id="@+id/titleFavorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="24dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_favorite" app:tint="@color/primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Favoritos" android:textColor="@color/on_background" android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:id="@+id/tvSeeMoreFavorites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Ver más →"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_input_pill"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_app_logo" app:tint="@color/primary" /></FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cálculo Vectorial" android:textColor="@color/on_background" android:textStyle="bold" android:textSize="13sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cálculo - hace 1 día" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_input_pill" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:text="PDF" android:textColor="@color/primary" android:textStyle="bold" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Normas y Políticas -->
        <TextView
            android:id="@+id/titleRules"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Normas y Políticas"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="24dp" app:cardElevation="2dp" app:strokeWidth="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:id="@+id/btnPrivacy" android:layout_width="match_parent" android:layout_height="64dp" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_input_pill"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_app_logo" app:tint="@color/primary" /></FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Políticas de Privacidad" android:textColor="@color/on_background" android:textStyle="bold" android:textSize="14sp" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:rotation="-90" android:src="@drawable/ic_chevron_down" app:tint="@color/placeholder" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="20dp" android:background="@color/outline_variant" />
                <LinearLayout android:id="@+id/btnNorms" android:layout_width="match_parent" android:layout_height="64dp" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:clickable="true" android:focusable="true" android:background="?attr/selectableItemBackground">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_input_pill"><ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_notification" app:tint="@color/primary" /></FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Normas de ClassDrop" android:textColor="@color/on_background" android:textStyle="bold" android:textSize="14sp" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:rotation="-90" android:src="@drawable/ic_chevron_down" app:tint="@color/placeholder" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Help Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp" app:cardBackgroundColor="@color/file_pdf_bg" app:cardCornerRadius="24dp" app:cardElevation="0dp" app:strokeWidth="0dp">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="24dp">
                <TextView android:id="@+id/tvHelpTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="¿Necesitas ayuda?" android:textColor="@color/on_background" android:textSize="18sp" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/tvHelpDescription"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="16dp"
                    android:text="Si tienes alguna duda, queja o comentario sobre ClassDrop, puedes comunicarte con el equipo de The Sync escribenos a:\nsoporte.classdrop@gmail.com"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    app:layout_constraintEnd_toStartOf="@id/ivHelpIcon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvHelpTitle" />
                
                <com.google.android.material.card.MaterialCardView 
                    android:id="@+id/ivHelpIcon" 
                    android:layout_width="64dp" 
                    android:layout_height="64dp" 
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="32dp" 
                    app:cardElevation="4dp" 
                    app:layout_constraintBottom_toBottomOf="parent" 
                    app:layout_constraintEnd_toEndOf="parent" 
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView 
                        android:layout_width="28dp" 
                        android:layout_height="28dp" 
                        android:layout_gravity="center" 
                        android:src="@drawable/ic_help" 
                        app:tint="@color/primary" />
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/file_pink_bg"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textColor="@color/error"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/error"
            app:iconGravity="textStart" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>