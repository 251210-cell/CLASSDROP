<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/uploadAreaUrl"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/bg_dashed_upload"
        android:layerType="software"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_link"
            app:tint="@color/primary"
            android:contentDescription="Icono de enlace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="ENLACE DEL APUNTE"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_pill"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_link"
                app:tint="@color/primary"
                android:contentDescription="Icono de link" />

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:hint="https://github.com/usuario"
                android:inputType="textUri"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="@color/placeholder"
                android:textSize="13sp"
                android:importantForAutofill="no" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>