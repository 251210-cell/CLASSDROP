<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="background">#F8FAFC</color>
    <color name="black">#000000</color>
    <color name="error">#EF4444</color>
    <color name="on_background">#0F172A</color>
    <color name="on_error">#FFFFFF</color>
    <color name="on_primary">#FFFFFF</color>
    <color name="on_surface">#0F172A</color>
    <color name="on_surface_variant">#475569</color>
    <color name="outline">#E2E8F0</color>
    <color name="outline_variant">#F1F5F9</color>
    <color name="placeholder">#94A3B8</color>
    <color name="primary">#6366F1</color>
    <color name="primary_dark">#4F46E5</color>
    <color name="success">#22C55E</color>
    <color name="surface">#FFFFFF</color>
    <color name="surface_variant">#F3F3F5</color>
    <color name="text_secondary">#64748B</color>
    <color name="transparent">#00000000</color>
    <color name="warning">#F59E0B</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">ClassDrop</string>
    <string name="nav_explorar">Explorar</string>
    <string name="nav_inicio">Inicio</string>
    <string name="nav_perfil">Perfil</string>
    <string name="nav_subir">Subir archivo</string>
    <style name="Theme.ClassDrop" parent="Theme.Material3.Light.NoActionBar">

        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOutline">@color/outline</item>

        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>

        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" ns1:targetApi="23">true</item>
        <item name="android:windowLightNavigationBar" ns1:targetApi="27">true</item>
    </style>
    <style name="Widget.ClassDrop.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Widget.ClassDrop.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">28dp</item>
        <item name="boxCornerRadiusTopEnd">28dp</item>
        <item name="boxCornerRadiusBottomStart">28dp</item>
        <item name="boxCornerRadiusBottomEnd">28dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxBackgroundColor">@color/surface_variant</item>
        <item name="hintEnabled">false</item>
    </style>
</resources>